# GENERATED BY matugen — edit ~/niri-experiment/configs/templates/mako.
# Re-render with `rice <wallpaper>` or `matugen image <wallpaper>`.

font=JetBrainsMono Nerd Font 11
background-color={{colors.surface.default.hex}}
text-color={{colors.on_surface.default.hex}}
border-color={{colors.primary.default.hex}}
border-size=2
border-radius=6
progress-color=over {{colors.primary.default.hex}}30

width=380
height=140
padding=12
# margin=top,right,bottom,left — top=30 sits flush against waybar bottom edge;
# right=30 pushes well inward from screen edge
margin=30,30,8,8
max-icon-size=48
icon-location=left

anchor=top-right
layer=overlay
output=
max-visible=5
sort=-time
default-timeout=6000
ignore-timeout=0
group-by=app-name
history=1
max-history=50

on-button-left=invoke-default-action
on-button-right=dismiss
on-button-middle=none

[urgency=low]
border-color={{colors.outline.default.hex}}
default-timeout=4000

[urgency=normal]
border-color={{colors.primary.default.hex}}
default-timeout=6000

[urgency=critical]
border-color={{colors.error.default.hex}}
background-color={{colors.error_container.default.hex}}
default-timeout=0
