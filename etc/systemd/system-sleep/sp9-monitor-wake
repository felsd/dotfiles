#!/bin/sh
# Power on monitors after resume (SP9 surface_gpe / linux-surface#1183).
# Replaces swayidle's `after-resume` hook so the fix survives the DMS migration.
# Runs as root in the system context; reaches into daniel's session via XDG_RUNTIME_DIR.

case "$1" in
    post)
        case "$2" in
            suspend|hibernate|hybrid-sleep|suspend-then-hibernate)
                NIRI_SOCK=$(ls /run/user/1000/niri.*.sock 2>/dev/null | head -1)
                runuser -u daniel -- env \
                    XDG_RUNTIME_DIR=/run/user/1000 \
                    NIRI_SOCKET="$NIRI_SOCK" \
                    /usr/bin/niri msg action power-on-monitors || true
                ;;
        esac
        ;;
esac
